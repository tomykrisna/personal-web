{
  "name": "ovro-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy-firebase": "firebase deploy",
    "seed:portfolio": "node tools/portfolio-seed/seed-firestore.mjs --file tools/portfolio-seed/projects.json --collection portfolioProjects",
    "seed:portfolio:dry": "node tools/portfolio-seed/seed-firestore.mjs --file tools/portfolio-seed/projects.json --collection portfolioProjects --dry-run",
    "seed:portfolio:images": "node tools/portfolio-seed/upload-storage-images.mjs --file tools/portfolio-seed/projects.json --images-root tools/portfolio-seed/images --collection portfolioProjects",
    "seed:portfolio:sa": "node tools/portfolio-seed/seed-firestore.mjs --file tools/portfolio-seed/projects.json --collection portfolioProjects --service-account ./service-account.json",
    "seed:portfolio:images:sa": "node tools/portfolio-seed/upload-storage-images.mjs --file tools/portfolio-seed/projects.json --images-root tools/portfolio-seed/images --collection portfolioProjects --service-account ./service-account.json",
    "export:portfolio": "node tools/portfolio-seed/export-firestore-to-json.mjs",
    "export:portfolio:sa": "node tools/portfolio-seed/export-firestore-to-json.mjs --service-account ./service-account.json",
    "export:portfolio:to-seed": "node tools/portfolio-seed/export-firestore-to-json.mjs --out tools/portfolio-seed/projects.json",
    "export:portfolio:to-seed:sa": "node tools/portfolio-seed/export-firestore-to-json.mjs --out tools/portfolio-seed/projects.json --service-account ./service-account.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@nicky-lenaers/ngx-scroll-to": "^14.0.0",
    "@popperjs/core": "^2.11.8",
    "@primeuix/themes": "^1.2.3",
    "aos": "^2.3.4",
    "bootstrap": "^5.3.3",
    "countup.js": "^2.8.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.8.0",
    "gsap": "^3.12.7",
    "primeng": "^20.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "yarn": "^1.22.22",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.7",
    "@angular/cli": "^19.0.7",
    "@angular/compiler-cli": "^19.0.0",
    "@types/aos": "^3.0.7",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.2.5"
  }
}
